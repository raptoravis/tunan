# vision skill — 环境变量模板
#
# 用法: 复制本文件为 ~/.env (即 C:\Users\<你>\.env),填入你的 key 即可。
#   cp .env.example ~/.env            # macOS / Linux / Git Bash
#   copy .env.example %USERPROFILE%\.env   # Windows cmd
#
# vision.py 每次运行自动加载 ~/.env (真实环境变量优先;不会覆盖已设的真实 env)。
# 至少配置一个 provider 的 API key。未配置的 provider 会被跳过。
# 用 # 注释掉不需要的行。

# ── Provider API keys (至少一个) ────────────────────────────────────
# 重要：auto-detect 时按 key 在文件中的出现顺序决定优先级 — 谁写在前面就优先用谁。
# 比如下面 DASHSCOPE_API_KEY 在第一行,ARK_API_KEY 在第三行,如果两者都填了值,
# 则优先使用 DashScope(qwen)。想优先用豆包就把 ARK_API_KEY 挪到第一行。
DASHSCOPE_API_KEY=sk-your-dashscope-key
SILICONFLOW_API_KEY=sk-your-siliconflow-key
OPENAI_API_KEY=sk-your-openai-key
# ARK_API_KEY=your-ark-api-key          # 豆包 / 火山方舟 (Volcengine Ark); 在方舟 Agent Plan 控制台创建
# BD_API_KEY=your-bytedance-key       # 旧名，仍可用作 ARK_API_KEY 的别名

# ── 自定义 endpoint (可选,覆盖各 provider 默认 base_url) ───────────
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 任意 OpenAI 兼容端点(Azure / 本地模型 / OneAPI 等)都可接到上面的 *_BASE_URL。

# ── 默认 provider (可选) ───────────────────────────────────────────
# 省略时按 --provider 参数 > VISION_PROVIDER env > ~/.env 中先出现的 key 自动选。
# VISION_PROVIDER=doubao   # doubao(=ark/bytedance/BD_API_KEY) | qwen(=dashscope) | openai | siliconflow

# ── 模型覆盖 (可选) ────────────────────────────────────────────────
# 优先级: {PROVIDER}_VISION_MODEL > VISION_MODEL > 内置默认值
# DOUBAO_VISION_MODEL=doubao-seed-2-1-pro-260628
# DASHSCOPE_VISION_MODEL=qwen-vl-max   # 或 qwen-vl-plus / qvq-max
# OPENAI_VISION_MODEL=gpt-4o
# SILICONFLOW_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# VISION_MODEL=...                   # 全局回退（per-provider 未设时生效）

# ── 生成参数 (可选) ────────────────────────────────────────────────
# VISION_TEMPERATURE=0          # 0=确定性, 1=最随机
# VISION_MAX_TOKENS=4096        # 最大响应 token 数

# ── .env 文件位置 (可选) ───────────────────────────────────────────
# VISION_ENV_FILE=~/.env        # 默认即 ~/.env; 指向别处时用它覆盖
