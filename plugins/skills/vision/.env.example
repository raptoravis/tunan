# vision skill — 环境变量模板
#
# 用法: 复制本文件为 ~/.env (即 C:\Users\<你>\.env),填入你的 key 即可。
#   cp .env.example ~/.env            # macOS / Linux / Git Bash
#   copy .env.example %USERPROFILE%\.env   # Windows cmd
#
# vision.py 每次运行自动加载 ~/.env (真实环境变量优先;不会覆盖已设的真实 env)。
# 至少配置一个 provider 的 API key。未配置的 provider 会被跳过。
# 用 # 注释掉不需要的行。

# ── Provider API keys (至少一个) ────────────────────────────────────
SILICONFLOW_API_KEY=sk-your-siliconflow-key
DASHSCOPE_API_KEY=sk-your-dashscope-key
OPENAI_API_KEY=sk-your-openai-key
DOUBAO_API_KEY=your-doubao-key

# ── 自定义 endpoint (可选,覆盖各 provider 默认 base_url) ───────────
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 任意 OpenAI 兼容端点(Azure / 本地模型 / OneAPI 等)都可接到上面的 *_BASE_URL。

# ── 默认 provider (可选) ───────────────────────────────────────────
# 省略时按 --provider 参数 > 首个找到的 key 自动选。
# VISION_PROVIDER=siliconflow   # siliconflow | qwen(=dashscope) | openai | doubao

# ── 模型覆盖 (可选) ────────────────────────────────────────────────
# VISION_MODEL=...              # 全局覆盖所有 provider 的默认模型
# SILICONFLOW_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# DASHSCOPE_MODEL=qwen-vl-max   # 或 qwen-vl-plus / qvq-max
# OPENAI_MODEL=gpt-4o
# DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# ── 生成参数 (可选) ────────────────────────────────────────────────
# VISION_TEMPERATURE=0          # 0=确定性, 1=最随机
# VISION_MAX_TOKENS=4096        # 最大响应 token 数

# ── .env 文件位置 (可选) ───────────────────────────────────────────
# VISION_ENV_FILE=~/.env        # 默认即 ~/.env; 指向别处时用它覆盖
